# ── LLM 模型配置 ──
MODEL_NAME="qwen-max"
OPENAI_API_KEY="your-api-key-here"
OPENAI_API_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_MAX_TOOL_ROUNDS=10
LLM_REFLECTION_TEMPERATURE=0.1

# ── Agent 行为配置 ──
AGENT_COUNT=3
AGENT_TASK_WAIT_TIMEOUT=10.0
AGENT_REFLECTION_TOOL_THRESHOLD=2
AGENT_REFLECTION_TIME_MS=5000
AGENT_REFLECTION_RESULT_MAX_CHARS=2000

# ── 任务配置 ──
TASK_CHAT_TIMEOUT=300.0
TASK_CLAIM_TTL_SECONDS=300
TASK_MAX_RETRIES=3
TASK_SESSION_HISTORY_MAX_TURNS=3
TASK_SUMMARY_WINDOW_SIZE=3
TASK_SUMMARY_MAX_CHARS=800
TASK_SUMMARY_TURN_DETAIL_CHARS=500

# ── 集体知识阈值 ──
KNOWLEDGE_SKILL_MIN_CONFIDENCE=0.5
KNOWLEDGE_PATTERN_MIN_CONFIDENCE=0.3
KNOWLEDGE_LESSON_MIN_CONFIDENCE=0.2
KNOWLEDGE_MAX_LESSONS_IN_PROMPT=3

# ── 观测器配置 ──
OBSERVER_FLUSH_INTERVAL=1.0
OBSERVER_FLUSH_BATCH_SIZE=50
OBSERVER_TRACE_TRUNCATE_LEN=500

# ── 代码执行配置 ──
CODE_EXEC_TIMEOUT=120.0

# ── 会话持久化配置 ──
# 默认 SQLite（无额外依赖），可切换为 MySQL 或 PostgreSQL
# SQLite:     sqlite:///swarm/data/sessions.db
# MySQL:      mysql://user:pass@127.0.0.1:3306/swarm     (需 pip install 'swarm-agent[mysql]')
# PostgreSQL: postgresql://user:pass@127.0.0.1:5432/swarm (需 pip install 'swarm-agent[pgsql]')
SESSION_DB_URL="sqlite:///swarm/data/sessions.db"
SESSION_FACT_MAX_PER_SESSION=50
# 连接池参数（仅 MySQL / PostgreSQL 生效，SQLite 自动使用单连接复用）
SESSION_POOL_SIZE=5
SESSION_POOL_MAX_OVERFLOW=10
SESSION_POOL_RECYCLE=3600

# 技能热插拔配置（需 pip install 'swarm-agent[hotloader]'）
SKILL_HOTLOADER_ENABLED=true
SKILL_HOTLOADER_WATCH_DIR=swarm/skills/builtin
# Markdown 技能目录（可选，默认与 SKILL_HOTLOADER_WATCH_DIR 相同）
# SKILL_MD_WATCH_DIR=path/to/your/md/skills
